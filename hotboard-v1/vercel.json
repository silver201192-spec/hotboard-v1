{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/hotspots.json",
      "headers": [
        {
          "key": "cache-control",
          "value": "public, max-age=300"
        }
      ]
    }
  ]
}
